import logging
from typing import List, Optional

from fastapi import Depends, HTTPException, status
from fastapi.security import OAuth2PasswordBearer
from jose import JWTError, jwt
from sqlalchemy.orm import Session

from config import settings
from app.db.database import get_db
from app.models.session import Session as SessionModel
from app.models.user import User

# Security Logger
security_logger = logging.getLogger("security")
security_logger.setLevel(logging.WARNING)
security_handler = logging.FileHandler("logs/security.log")
security_handler.setFormatter(logging.Formatter("%(asctime)s - SECURITY - %(levelname)s - %(message)s"))
security_logger.addHandler(security_handler)

# Define OAuth2 scheme here or import if circular dependency allows. 
# Better to define it here or in a base config to avoid importing from app.api.routes.
oauth2_scheme = OAuth2PasswordBearer(tokenUrl="auth/token")


def get_current_user(token: str = Depends(oauth2_scheme), db: Session = Depends(get_db)) -> User:
    """
    Get current authenticated user with session timeout check (UC_09).
    """
    credentials_exception = HTTPException(
        status_code=status.HTTP_401_UNAUTHORIZED,
        detail="Could not validate credentials",
        headers={"WWW-Authenticate": "Bearer", "X-Redirect": "/login"},
    )
    
    try:
        payload = jwt.decode(token, settings.SECRET_KEY, algorithms=[settings.ALGORITHM])
        user_id: Optional[str] = payload.get("sub")
        
        if user_id is None:
            security_logger.warning("Invalid token: Missing user ID in payload")
            raise credentials_exception
            
    except JWTError as e:
        security_logger.warning(f"JWT decode failed: {str(e)}")
        raise credentials_exception
        
    user = db.query(User).filter(User.user_id == int(user_id)).first()
    
    if user is None:
        security_logger.warning(f"User not found for ID: {user_id}")
        raise credentials_exception
    
    # UC_09: Check session timeout (BF_04, BF_05)
    active_sessions = db.query(SessionModel).filter(
        SessionModel.user_id == user.user_id,
        SessionModel.status == "active"
    ).all()
    
    # Check if any session is still active (not expired)
    has_active_session = False
    
    for session in active_sessions:
        if not session.is_session_expired(settings.SESSION_TIMEOUT_DURATION):
            has_active_session = True
            break
        else:
            # Mark expired session as inactive
            session.status = "inactive"
            security_logger.info(f"Session {session.session_id} expired for user {user.email}")
    
    if not has_active_session and active_sessions:
        db.commit()
        security_logger.warning(f"All sessions expired for user {user.email}")
        raise HTTPException(
            status_code=status.HTTP_401_UNAUTHORIZED,
            detail="Session expired due to inactivity. Please login again.",
            headers={"WWW-Authenticate": "Bearer", "X-Redirect": "/login"},
        )
    
    db.commit()
    return user


class RoleChecker:
    def __init__(self, allowed_roles: List[str]):
        self.allowed_roles = allowed_roles

    def __call__(self, user: User = Depends(get_current_user)) -> bool:
        # AF_A2: Session Role Error (Partially handled here)
        # We assume get_current_user ensures the user exists and is active.
        # Now we check the role.
        
        if not user.role:
            # If user has no role assigned for some reason
            security_logger.error(f"User {user.email} (ID: {user.user_id}) has no role assigned")
            raise HTTPException(
                status_code=status.HTTP_401_UNAUTHORIZED, 
                detail="User has no role assigned",
                headers={"X-Redirect": "/login"}
            )

        if user.role.name not in self.allowed_roles:
            # AF_A1: Unauthorized Access / Access denied
            security_logger.warning(
                f"Access denied: User {user.email} (Role: {user.role.name}) "
                f"attempted to access resource requiring roles: {self.allowed_roles}"
            )
            raise HTTPException(
                status_code=status.HTTP_403_FORBIDDEN, 
                detail="Not enough permissions",
                headers={"X-Return-To-Previous": "true"}
            )
            
        return True
