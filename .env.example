# Environment variables for Bizify - Template
# Copy this file to .env and fill in the values

# General
APP_ENV=development
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/bizify
SECRET_KEY=your-long-random-secret-key-here
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Rate Limiting
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379

# Admin Persistence
ALLOW_ADMIN_BOOTSTRAP=false
ADMIN_BOOTSTRAP_TOKEN=

# AI Pipeline
AI_PROVIDER=mock
OPENAI_API_KEY=

# Email Configuration
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_TLS=true
MAIL_SSL=false
