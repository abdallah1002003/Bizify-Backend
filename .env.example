# Database (required)
# PostgreSQL example:
DATABASE_URL=postgresql+psycopg2://localhost:5432/postgres
# Optional for test runs:
# TEST_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/p7_test

# Security (required in non-local environments)
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# App
APP_ENV=development
AUTO_CREATE_TABLES=false
VERIFY_DB_ON_STARTUP=true
RATE_LIMIT_PER_MINUTE=120
ALLOW_ADMIN_BOOTSTRAP=false
# One-time setup secret for POST /api/v1/auth/bootstrap-admin
ADMIN_BOOTSTRAP_TOKEN=replace-with-random-bootstrap-token

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true

# AI runtime
# Options: mock | openai
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
AI_REQUEST_TIMEOUT_SECONDS=30
