# Environment variables for Bizify - Template
# Copy this file to .env and fill in the values

# General
APP_ENV=development
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/bizify
SECRET_KEY=your-long-random-secret-key-here
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Rate Limiting
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379

# Admin Persistence
ALLOW_ADMIN_BOOTSTRAP=false
ADMIN_BOOTSTRAP_TOKEN=

# AI Pipeline
AI_PROVIDER=mock
OPENAI_API_KEY=

# Email Configuration
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@bizify.app
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_TLS=true
MAIL_SSL=false
MAIL_ENABLED=true
FRONTEND_URL=http://localhost:3000

# JWT Signing (RS256 — production only)
# Leave blank in development/test to use HS256 + SECRET_KEY.
# Generate keys: python scripts/generate_rsa_keys.py
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Stripe (production only)
# Run: stripe listen --forward-to localhost:8001/api/v1/billing/webhooks/stripe
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Field-level Encryption (AES-256-GCM)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=

# Sentry Error Tracking
SENTRY_DSN=
